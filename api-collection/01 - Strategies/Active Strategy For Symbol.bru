meta {
  name: Active Strategy For Symbol
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/strategies/AAPL/active
  body: none
  auth: none
}

headers {
  X-API-Key: {{apiKey}}
}

docs {
  Returns the currently active strategy name for a single symbol. 404 if no
  strategy is bound to the symbol yet.
}
