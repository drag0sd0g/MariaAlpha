# Copy to .env.local and fill in. Vite injects VITE_* vars at build time.
# This must match the value in the repo-root .env file used by docker-compose.
VITE_MARIAALPHA_API_KEY=

# Leave blank to use the Vite dev proxy (recommended for local dev).
# Set to http://localhost:8080 when running `vite preview` against a built bundle.
VITE_API_BASE_URL=
